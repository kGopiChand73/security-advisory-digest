# Copy this file to `.env` and fill values.

# LLM provider: "openai" or "mock"
# Use "mock" to run end-to-end with NO api key (rule-based summary).
LLM_PROVIDER=mock

# Required only if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# How many advisories to pull per feed (keep small for the PoC)
MAX_ITEMS_PER_FEED=30

# RAG: top-K advisories to retrieve per stack item
TOP_K=3

# Similarity threshold (0-1). Lower = more matches, higher = stricter.
SIMILARITY_THRESHOLD=0.35
